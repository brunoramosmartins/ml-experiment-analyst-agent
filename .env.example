# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Anthropic API key — required for the agent (claude-sonnet-4-5)
ANTHROPIC_API_KEY=sk-ant-...

# ─── Observability (LangSmith) ────────────────────────────────────────────────
# LangSmith API key — get yours at https://smith.langchain.com/
LANGCHAIN_API_KEY=lsv2_...

# Enable LangSmith tracing (set to "false" in CI to avoid sending traces)
LANGCHAIN_TRACING_V2=true

# LangSmith project name — traces will appear under this project
LANGCHAIN_PROJECT=ml-experiment-analyst

# ─── Web Search (Tavily) ──────────────────────────────────────────────────────
# Tavily API key — get yours at https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# ─── MLflow ───────────────────────────────────────────────────────────────────
# Tracking server URI — use the Docker Compose stack for development
MLFLOW_TRACKING_URI=http://localhost:5000

# MinIO / S3 credentials for MLflow artifact store (Docker Compose defaults)
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ─── Agent workspace ──────────────────────────────────────────────────────────
# Root directory for agent-generated reports and files
AGENT_WORKSPACE_PATH=data/agent-workspace
